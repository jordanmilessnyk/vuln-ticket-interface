SNYK_TOKEN=your-snyk-api-token-here
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True

# Path to the snyk-jira-sync binary downloaded from:
# https://github.com/snyk-tech-services/jira-tickets-for-new-vulns/releases
# Examples:
#   SNYK_JIRA_BINARY=/usr/local/bin/snyk-jira-sync-macOs
#   SNYK_JIRA_BINARY=./snyk-jira-sync-macOs
SNYK_JIRA_BINARY=snyk-jira-sync
